APP_HOST=0.0.0.0
APP_PORT=10122
APP_DATA_DIR=/data
APP_DB=/data/backup_verify.sqlite3
RESULTS_FILE=/opt/backup-verify/results.json

VERIFY_SCHEDULE=0 2 * * 0
SCHEDULE_ENABLED=true
SCHEDULE_FREQUENCY=weekly
SCHEDULE_TIME=02:00
SCHEDULE_DAY_OF_WEEK=0
SCHEDULE_DAY_OF_MONTH=1
VERIFY_TIMEZONE=America/New_York

SAMPLE_SIZE=87
# Initial clients are seeded into SQLite on first start only. Manage clients in the dashboard after that.
CLIENTS=MichaelD-ASUS,MichaelD-Lenovo
CRITICAL_PATHS=Windows,Users,Program Files,ProgramData
BACKUP_ROOT=/mnt/qnap-backups/urbackup
BACKUP_AGE_THRESHOLD_DAYS=2
SIZE_DROP_THRESHOLD_PERCENT=30
RETENTION_MIN_COPIES=2

URBACKUP_URL=http://10.10.10.76:55414
URBACKUP_USERNAME=YOUR_URBACKUP_USERNAME
URBACKUP_PASSWORD=YOUR_URBACKUP_PASSWORD
PROXMOX_URL=https://10.10.10.251:8006
PROXMOX_TOKEN_ID=YOUR_PROXMOX_TOKEN_ID
PROXMOX_TOKEN_SECRET=YOUR_PROXMOX_TOKEN_SECRET

SMART_DEVICES=auto
SMARTCTL_PATH=smartctl
QNAP_URL=https://10.10.10.230
QNAP_USERNAME=YOUR_QNAP_USERNAME
QNAP_PASSWORD=YOUR_QNAP_PASSWORD

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_HOME_CHANNEL=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_ENV_PATH=/host-hermes/.env
SMTP_ENABLED=false
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=backup@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_TO=michael@example.com
SMTP_FROM=backup@example.com
GOTIFY_ENABLED=false
GOTIFY_URL=http://10.10.10.237:10143
GOTIFY_TOKEN=YOUR_GOTIFY_TOKEN
NOTIFY_ON_COMPLETION=true
NOTIFY_ON_FAILURE_ONLY=false
NOTIFY_ON_WARNING=true
NOTIFY_ON_DISK_HEALTH_CHANGE=true
QUIET_HOURS_START=
QUIET_HOURS_END=

B2_ENABLED=false
B2_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_APPLICATION_KEY
B2_BUCKET_NAME=YOUR_B2_BUCKET
B2_BEHIND_DAYS=2
